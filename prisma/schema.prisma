generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  PURCHASING_MANAGER
  INVENTORY_MANAGER
  SALES_REP
  SALES_MANAGER
  ACCOUNTING_MANAGER
  AP_ANALYST
  AR_ANALYST
  ADMIN
}

enum ItemType {
  INVENTORY
  NON_INVENTORY
  SERVICE
}

enum AdjustmentType {
  INCREASE
  DECREASE
}

enum TransferStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum POStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  BILLED
  PAID
  CANCELLED
}

enum GRStatus {
  DRAFT
  CONFIRMED
}

enum BillStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CHECK
}

enum SOStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PROCESSING
  PICKING
  PACKING
  SHIPPED
  INVOICED
  PAID
  CANCELLED
}

enum PickStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PackStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum ShipStatus {
  DRAFT
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrdersCreated    PurchaseOrder[]       @relation("POCreatedBy")
  goodsReceiptsCreated     GoodsReceipt[]        @relation("GRReceivedBy")
  vendorBillsCreated       VendorBill[]          @relation("BillCreatedBy")
  vendorBillsApproved      VendorBill[]          @relation("BillApprovedBy")
  billPaymentsMade         BillPayment[]         @relation("PaymentMadeBy")
  salesOrdersCreated       SalesOrder[]          @relation("SOCreatedBy")
  salesOrdersApproved      SalesOrder[]          @relation("SOApprovedBy")
  pickOrdersBy             PickOrder[]           @relation("PickedBy")
  packOrdersBy             PackOrder[]           @relation("PackedBy")
  shipmentsBy              Shipment[]            @relation("ShippedBy")
  invoicesCreated          Invoice[]             @relation("InvoiceCreatedBy")
  customerPaymentsReceived CustomerPayment[]     @relation("PaymentReceivedBy")
  inventoryAdjustments     InventoryAdjustment[] @relation("AdjustedBy")
  inventoryTransfers       InventoryTransfer[]   @relation("TransferredBy")

  @@map("users")
}

model Supplier {
  id            String   @id @default(cuid())
  supplierCode  String   @unique
  supplierName  String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  vendorBills    VendorBill[]

  @@map("suppliers")
}

model Customer {
  id            String   @id @default(cuid())
  customerCode  String   @unique
  customerName  String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  creditLimit   Decimal  @default(0) @db.Decimal(15, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salesOrders SalesOrder[]
  invoices    Invoice[]

  @@map("customers")
}

model Warehouse {
  id            String   @id @default(cuid())
  warehouseName String
  location      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryStocks InventoryStock[]
  goodsReceipts   GoodsReceipt[]
  transfersFrom   InventoryTransfer[] @relation("TransferFrom")
  transfersTo     InventoryTransfer[] @relation("TransferTo")
  pickOrders      PickOrder[]

  @@map("warehouses")
}

model Item {
  id          String   @id @default(cuid())
  itemCode    String   @unique
  itemName    String
  itemType    ItemType
  description String?
  unitPrice   Decimal  @default(0) @db.Decimal(15, 2)
  costPrice   Decimal  @default(0) @db.Decimal(15, 2)
  unit        String   @default("pcs")
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventoryStocks      InventoryStock[]
  inventoryAdjustments InventoryAdjustment[]
  inventoryTransfers   InventoryTransfer[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiptItems    GoodsReceiptItem[]
  salesOrderItems      SalesOrderItem[]

  @@map("items")
}

model InventoryStock {
  id          String   @id @default(cuid())
  itemId      String
  warehouseId String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
  @@map("inventory_stocks")
}

model InventoryAdjustment {
  id             String         @id @default(cuid())
  itemId         String
  warehouseId    String
  adjustmentType AdjustmentType
  quantity       Int
  reason         String?
  adjustedById   String
  createdAt      DateTime       @default(now())

  item       Item @relation(fields: [itemId], references: [id])
  adjustedBy User @relation("AdjustedBy", fields: [adjustedById], references: [id])

  @@map("inventory_adjustments")
}

model InventoryTransfer {
  id              String         @id @default(cuid())
  transferNumber  String         @unique
  itemId          String
  fromWarehouseId String
  toWarehouseId   String
  quantity        Int
  status          TransferStatus @default(DRAFT)
  notes           String?
  transferredById String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  item          Item      @relation(fields: [itemId], references: [id])
  fromWarehouse Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])
  transferredBy User      @relation("TransferredBy", fields: [transferredById], references: [id])

  @@map("inventory_transfers")
}

// ─── PROCURE TO PAY ──────────────────────────────────────────────────────────

model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  createdById  String
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  totalAmount  Decimal   @default(0) @db.Decimal(15, 2)
  status       POStatus  @default(DRAFT)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  createdBy     User                @relation("POCreatedBy", fields: [createdById], references: [id])
  items         PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]
  vendorBills   VendorBill[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id        String  @id @default(cuid())
  poId      String
  itemId    String
  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2)
  subtotal  Decimal @db.Decimal(15, 2)

  purchaseOrder     PurchaseOrder      @relation(fields: [poId], references: [id], onDelete: Cascade)
  item              Item               @relation(fields: [itemId], references: [id])
  goodsReceiptItems GoodsReceiptItem[]

  @@map("purchase_order_items")
}

model GoodsReceipt {
  id           String   @id @default(cuid())
  grNumber     String   @unique
  poId         String
  receivedById String
  warehouseId  String
  receivedDate DateTime @default(now())
  status       GRStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrder PurchaseOrder      @relation(fields: [poId], references: [id])
  receivedBy    User               @relation("GRReceivedBy", fields: [receivedById], references: [id])
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  items         GoodsReceiptItem[]
  vendorBills   VendorBill[]

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id               String @id @default(cuid())
  grId             String
  poItemId         String
  itemId           String
  quantityOrdered  Int
  quantityReceived Int

  goodsReceipt GoodsReceipt      @relation(fields: [grId], references: [id], onDelete: Cascade)
  poItem       PurchaseOrderItem @relation(fields: [poItemId], references: [id])
  item         Item              @relation(fields: [itemId], references: [id])

  @@map("goods_receipt_items")
}

model VendorBill {
  id            String     @id @default(cuid())
  billNumber    String     @unique
  poId          String
  grId          String?
  supplierId    String
  billDate      DateTime   @default(now())
  dueDate       DateTime
  totalAmount   Decimal    @db.Decimal(15, 2)
  paidAmount    Decimal    @default(0) @db.Decimal(15, 2)
  status        BillStatus @default(DRAFT)
  rejectionNote String?
  createdById   String
  approvedById  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  goodsReceipt  GoodsReceipt? @relation(fields: [grId], references: [id])
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  createdBy     User          @relation("BillCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?         @relation("BillApprovedBy", fields: [approvedById], references: [id])
  payments      BillPayment[]

  @@map("vendor_bills")
}

model BillPayment {
  id              String        @id @default(cuid())
  paymentNumber   String        @unique
  billId          String
  amount          Decimal       @db.Decimal(15, 2)
  paymentDate     DateTime      @default(now())
  paymentMethod   PaymentMethod
  referenceNumber String?
  notes           String?
  paidById        String
  createdAt       DateTime      @default(now())

  vendorBill VendorBill @relation(fields: [billId], references: [id])
  paidBy     User       @relation("PaymentMadeBy", fields: [paidById], references: [id])

  @@map("bill_payments")
}

// ─── ORDER TO CASH ───────────────────────────────────────────────────────────

model SalesOrder {
  id              String    @id @default(cuid())
  soNumber        String    @unique
  customerId      String
  createdById     String
  approvedById    String?
  orderDate       DateTime  @default(now())
  deliveryDate    DateTime?
  totalAmount     Decimal   @db.Decimal(15, 2)
  status          SOStatus  @default(DRAFT)
  rejectionReason String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer   Customer         @relation(fields: [customerId], references: [id])
  createdBy  User             @relation("SOCreatedBy", fields: [createdById], references: [id])
  approvedBy User?            @relation("SOApprovedBy", fields: [approvedById], references: [id])
  items      SalesOrderItem[]
  pickOrders PickOrder[]
  invoices   Invoice[]
  shipments  Shipment[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id        String  @id @default(cuid())
  soId      String
  itemId    String
  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2)
  subtotal  Decimal @db.Decimal(15, 2)

  salesOrder SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id])

  @@map("sales_order_items")
}

model PickOrder {
  id          String     @id @default(cuid())
  soId        String
  warehouseId String
  pickedById  String
  pickDate    DateTime   @default(now())
  status      PickStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  salesOrder SalesOrder @relation(fields: [soId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  pickedBy   User       @relation("PickedBy", fields: [pickedById], references: [id])
  packOrder  PackOrder?

  @@map("pick_orders")
}

model PackOrder {
  id           String     @id @default(cuid())
  pickOrderId  String     @unique
  packedById   String
  packDate     DateTime   @default(now())
  packageCount Int        @default(1)
  totalWeight  Decimal?   @db.Decimal(8, 2)
  status       PackStatus @default(DRAFT)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  pickOrder PickOrder @relation(fields: [pickOrderId], references: [id])
  packedBy  User      @relation("PackedBy", fields: [packedById], references: [id])
  shipment  Shipment?

  @@map("pack_orders")
}

model Shipment {
  id             String     @id @default(cuid())
  shipmentNumber String     @unique
  packOrderId    String     @unique
  soId           String
  shippedById    String
  shipDate       DateTime   @default(now())
  trackingNumber String?
  carrier        String?
  status         ShipStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  packOrder   PackOrder   @relation(fields: [packOrderId], references: [id])
  salesOrder  SalesOrder  @relation(fields: [soId], references: [id])
  shippedBy   User        @relation("ShippedBy", fields: [shippedById], references: [id])

  @@map("shipments")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  soId          String
  customerId    String
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime
  totalAmount   Decimal       @db.Decimal(15, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(15, 2)
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  salesOrder SalesOrder        @relation(fields: [soId], references: [id])
  customer   Customer          @relation(fields: [customerId], references: [id])
  createdBy  User              @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  payments   CustomerPayment[]

  @@map("invoices")
}

model CustomerPayment {
  id              String        @id @default(cuid())
  paymentNumber   String        @unique
  invoiceId       String
  amount          Decimal       @db.Decimal(15, 2)
  paymentDate     DateTime      @default(now())
  paymentMethod   PaymentMethod
  referenceNumber String?
  notes           String?
  receivedById    String
  createdAt       DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  receivedBy User    @relation("PaymentReceivedBy", fields: [receivedById], references: [id])

  @@map("customer_payments")
}
